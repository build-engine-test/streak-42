# Default placeholders. Build Engine appends plan-required env vars below.

# Postgres connection string (set per-build by Deployer)
DATABASE_URL=

# Better Auth session secret (auto-generated per build)
BETTER_AUTH_SECRET=

# Required by plan
# Public base URL of the deployed app (e.g. https://streak.onrender.com). Used by Better Auth for cookie domain + callbacks.
BETTER_AUTH_URL=
